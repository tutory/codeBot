GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_BASE_BRANCH=develop
GITHUB_EASY_LABEL=easy
GITHUB_BUG_LABEL=bug
CODEBOT_BRANCH_NAME_TEMPLATE={branchType}-{issueNumber}-{slug}
CODEBOT_COMMIT_MESSAGE_TEMPLATE=#{issueNumber}: {reason}
GITHUB_ASSIGNEE=bot-account
CODEBOT_IGNORE_SELF_COMMENTS=true
CODEBOT_GITHUB_COMMENT_PREFIX=🤖
CODEBOT_REPO_PATH=/absolute/path/to/local/repo
CODEBOT_CREATE_DRAFT_PRS=false
CODEBOT_DRY_RUN=true
CODEBOT_POLL_SECONDS=300
CODEBOT_MODEL=gpt-5.4
CODEBOT_SOLVER_COMMAND=node scripts/solve-issue.js
CODEBOT_STATE_FILE=.codebot/state.json
